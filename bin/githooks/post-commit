#!/bin/sh

# Custom post-commit hook that runs the linter.

action() {
    # just lint
    if [ ! -d "${TT_SEMILEPTONIC_BASE}" ]; then
        >&2 echo "TT_SEMILEPTONIC_BASE not setup, skip linting"
    elif [ "${TT_SEMILEPTONIC_SKIP_POST_COMMIT}" != "1" ]; then
        echo "post-commit linting ..."
        bash "${TT_SEMILEPTONIC_BASE}/tests/run_linting"
        echo
    fi

    # always end successfully
    return "0"
}
action "$@"
